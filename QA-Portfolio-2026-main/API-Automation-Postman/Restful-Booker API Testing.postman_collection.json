    {
      "name": "Post data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Parse the response into JSON",
              "var jsonData = pm.response.json();",
              "",
              "// 2. Save the bookingid to the environment variable",
              "pm.environment.set(\"bookingId\", jsonData.bookingid);",
              "",
              "console.log(\"Saved new ID: \" + jsonData.bookingid);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstname\" : \"Tester\",\n    \"lastname\" : \"Ace\",\n    \"totalprice\" : 150,\n    \"depositpaid\" : true,\n    \"bookingdates\" : {\n        \"checkin\" : \"2026-03-01\",\n        \"checkout\" : \"2026-03-05\"\n    },\n    \"additionalneeds\" : \"Late Checkout\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/booking",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "booking"
          ]
        },
        "description": "This is a POST request, submitting data to an API via the request body. This request submits JSON data, and the data is reflected in the response.\n\nA successful POST request typically returns a `200 OK` or `201 Created` response code."
      },
      "response": []
