    {
      "name": "Get Booking by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"FirstName should be Tester\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.firstname).to.eql(\"Tester\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "token=4925684255d8d82",
            "type": "text"
